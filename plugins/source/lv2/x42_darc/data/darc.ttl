		a lv2:AudioPort ,
			lv2:OutputPort ;
		lv2:index 11 ;
		lv2:symbol "outL" ;
		lv2:name "Out Left"
	] , [
		a lv2:AudioPort ,
			lv2:InputPort ;
		lv2:index 12 ;
		lv2:symbol "inR" ;
